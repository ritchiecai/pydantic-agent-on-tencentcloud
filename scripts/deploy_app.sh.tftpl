#!/usr/bin/env bash
# TAT command content (rendered by `templatefile` in infra/main.tf, then run by
# the TencentCloud Automation Tools agent via tencentcloud_tat_command).
# Runs on the CVM whenever the TAT command is invoked. It:
#   1. writes the model env file (mode 0600),
#   2. installs uv + clones (or pulls) the app repo + syncs deps,
#   3. installs/refreshes a systemd unit that runs uvicorn.
# Idempotent: safe to re-invoke from the console/CLI for debugging or redeploy.
set -euo pipefail

# --- 1. env file (secrets) ---------------------------------------------------
install -d -m 0750 /etc/agent
# 应用文件日志目录（LOG_FILE 落点，见下方 env）。
install -d -m 0750 /var/log/agent
cat >/etc/agent/env <<'ENVEOF'
MODEL_PROVIDER=${model_provider}
MODEL_STRING=${model_string}
MODEL_API_KEY=${model_api_key}
MODEL_BASE_URL=${model_base_url}
# 腾讯云 Agent Runtime（代码沙箱，E2B 兼容）
E2B_API_KEY=${runtime_api_key}
SANDBOX_TEMPLATE=${sandbox_template}
E2B_DOMAIN=${runtime_domain}
# 腾讯云数据库 Agent Memory（跨会话记忆）
AGENT_MEMORY_ENDPOINT=${memory_endpoint}
AGENT_MEMORY_API_KEY=${memory_api_key}
AGENT_MEMORY_SERVICE_ID=${memory_service_id}
LOG_FILE=/var/log/agent/app.log
ENVEOF
chmod 600 /etc/agent/env

# --- 2. app code + deps ------------------------------------------------------
export HOME=/root
# Install uv if missing.
if ! command -v uv >/dev/null 2>&1; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi
# uv on PATH for non-interactive shells.
export PATH="$HOME/.local/bin:$PATH"

APP_DIR=/opt/agent
APP_GIT_REPO="${app_git_repo}"
APP_GIT_REF="${app_git_ref}"
echo "[deploy] app source: $APP_GIT_REPO @ $APP_GIT_REF"

# 确保 git 可用（精简镜像可能未预装），否则后续 clone 会因 set -e 中断。
if ! command -v git >/dev/null 2>&1; then
  yum install -y git
fi

# 切换 repo URL 时连带把现有仓库视作脏目录，重新 clone（避免远端不一致冲突）。
if [ -d "$APP_DIR/.git" ]; then
  current_origin=$(git -C "$APP_DIR" remote get-url origin 2>/dev/null || true)
  if [ -n "$current_origin" ] && [ "$current_origin" != "$APP_GIT_REPO" ]; then
    echo "[deploy] origin changed ($current_origin -> $APP_GIT_REPO); re-cloning"
    rm -rf "$APP_DIR"
  fi
fi
if [ -d "$APP_DIR" ] && [ ! -d "$APP_DIR/.git" ]; then
  # 目录存在但不是 git 仓库，清掉残留后重新 clone，避免 uv sync 跑在脏目录上。
  rm -rf "$APP_DIR"
fi
install -d -m 0755 "$APP_DIR"

if [ ! -d "$APP_DIR/.git" ]; then
  # 首次 clone：--branch 既支持分支也支持 tag；commit sha 不被 --branch 接受，
  # 因此先按默认分支 clone，再 checkout 到目标 ref（兼容三种 ref 形态）。
  if git clone --branch "$APP_GIT_REF" --single-branch "$APP_GIT_REPO" "$APP_DIR" 2>/dev/null; then
    echo "[deploy] cloned $APP_GIT_REF directly"
  else
    echo "[deploy] $APP_GIT_REF is not a branch/tag; clone default then checkout"
    git clone "$APP_GIT_REPO" "$APP_DIR"
    git -C "$APP_DIR" checkout --detach "$APP_GIT_REF"
  fi
else
  # 已存在仓库：抓最新引用后 checkout 到目标 ref；若是分支则再 ff-only pull
  # 把分支推进到 origin/<ref>。tag 与 commit sha 不需要 pull。
  git -C "$APP_DIR" fetch --tags --prune origin
  git -C "$APP_DIR" checkout --force "$APP_GIT_REF"
  if git -C "$APP_DIR" show-ref --verify --quiet "refs/heads/$APP_GIT_REF"; then
    git -C "$APP_DIR" reset --hard "origin/$APP_GIT_REF"
  fi
fi
cd "$APP_DIR"
echo "[deploy] checked out: $(git rev-parse --short HEAD) ($APP_GIT_REF)"
# 启用 memory-sdk extra：vendor/ 下的 wheel 随 git 一并到达 CVM。
# - 真 wheel 在位：装上腾讯云 Agent Memory 官方 SDK，自动启用 _SdkBackend。
# - 占位 wheel：装上后运行时仍 ImportError，MemoryClient 自动回退到 _HttpBackend，
#   功能等价、不影响 demo。
# 兼容性兜底：若远端代码尚未含 memory-sdk extra（如部署时的 git ref 落后于本地
# 改动），uv 0.11+ 会硬报 `Extra ... not defined`。此处探测 pyproject 后回退到
# 不带 extra 的 sync，避免部署被"未提交改动"卡住。
if grep -q '^memory-sdk' pyproject.toml 2>/dev/null \
   || grep -qE '^\s*memory-sdk\s*=' pyproject.toml 2>/dev/null; then
  uv sync --extra memory-sdk
else
  echo "[deploy] memory-sdk extra not declared in pyproject.toml; falling back to plain uv sync"
  uv sync
fi

# --- 3. systemd unit ---------------------------------------------------------
cat >/etc/systemd/system/agent.service <<'UNITEOF'
[Unit]
Description=pydantic-ai agent MVP (FastAPI + uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/agent
EnvironmentFile=/etc/agent/env
ExecStart=/root/.local/bin/uv run uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl daemon-reload
# 重新下发时用 restart 确保新代码/新 env 生效（enable 保证开机自启）。
systemctl enable agent.service
systemctl restart agent.service

# env 文件以 0600 保存密钥。TAT agent 执行结束后会自动清理临时脚本副本，
# 渲染内容（含密钥）不会作为 world-readable 文件残留在机器上。
