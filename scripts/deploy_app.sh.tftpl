#!/usr/bin/env bash
# TAT command content (rendered by `templatefile` in infra/main.tf, then run by
# the TencentCloud Automation Tools agent via tencentcloud_tat_command).
# Runs on the CVM whenever the TAT command is invoked. It:
#   1. writes the model env file (mode 0600),
#   2. installs uv + clones (or pulls) the app repo + syncs deps,
#   3. installs/refreshes a systemd unit that runs uvicorn.
# Idempotent: safe to re-invoke from the console/CLI for debugging or redeploy.
set -euo pipefail

# --- 1. env file (secrets) ---------------------------------------------------
install -d -m 0750 /etc/agent
# 应用文件日志目录（LOG_FILE 落点，见下方 env）。
install -d -m 0750 /var/log/agent
cat >/etc/agent/env <<'ENVEOF'
MODEL_PROVIDER=${model_provider}
MODEL_STRING=${model_string}
MODEL_API_KEY=${model_api_key}
MODEL_BASE_URL=${model_base_url}
LOG_FILE=/var/log/agent/app.log
ENVEOF
chmod 600 /etc/agent/env

# --- 2. app code + deps ------------------------------------------------------
export HOME=/root
# Install uv if missing.
if ! command -v uv >/dev/null 2>&1; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi
# uv on PATH for non-interactive shells.
export PATH="$HOME/.local/bin:$PATH"

APP_DIR=/opt/agent
# 确保 git 可用（精简镜像可能未预装），否则后续 clone 会因 set -e 中断。
if ! command -v git >/dev/null 2>&1; then
  yum install -y git
fi
if [ -d "$APP_DIR" ] && [ ! -d "$APP_DIR/.git" ]; then
  # 目录存在但不是 git 仓库，清掉残留后重新 clone，避免 uv sync 跑在脏目录上。
  rm -rf "$APP_DIR"
fi
install -d -m 0755 "$APP_DIR"
if [ ! -d "$APP_DIR/.git" ]; then
  git clone https://github.com/ritchiecai/pydantic-agent-on-tencentcloud.git "$APP_DIR"
else
  git -C "$APP_DIR" pull --ff-only
fi
cd "$APP_DIR"
uv sync

# --- 3. systemd unit ---------------------------------------------------------
cat >/etc/systemd/system/agent.service <<'UNITEOF'
[Unit]
Description=pydantic-ai agent MVP (FastAPI + uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/agent
EnvironmentFile=/etc/agent/env
ExecStart=/root/.local/bin/uv run uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl daemon-reload
# 重新下发时用 restart 确保新代码/新 env 生效（enable 保证开机自启）。
systemctl enable agent.service
systemctl restart agent.service

# env 文件以 0600 保存密钥。TAT agent 执行结束后会自动清理临时脚本副本，
# 渲染内容（含密钥）不会作为 world-readable 文件残留在机器上。
