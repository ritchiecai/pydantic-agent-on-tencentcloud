# 复制为 .env 后填入真实值（.env 已被 .gitignore 忽略，勿提交真实密钥）。

# 模型后端 provider：openai（默认）| deepseek | zhipu | tokenhub
MODEL_PROVIDER=openai

# pydantic-ai 模型串；常见取值：
#   openai   -> openai:gpt-4o-mini
#   deepseek -> deepseek-chat
#   zhipu    -> glm-4
#   tokenhub -> gpt-4o-mini（OpenAI 兼容，须配合 MODEL_BASE_URL）
MODEL_STRING=openai:gpt-4o-mini

# 模型 provider 的 API key（必填）
MODEL_API_KEY=sk-xxx

# OpenAI 兼容端点 base_url：tokenhub 等自定义端点在此设置；
# 留空走 provider 代码默认值（openai/deepseek/zhipu 无需设置）。
# MODEL_BASE_URL=http://<tokenhub-host>/tokenhub/v1

# —— 腾讯云 Agent Runtime（代码沙箱，E2B 兼容）——
# 控制台「API Keys」页面创建：https://console.cloud.tencent.com/ags/sandbox
# 形如 ark_xxxx。运行 /chat 时必填，缺则请求返回 500 并指出缺失变量。
E2B_API_KEY=ark_xxx
# 控制台「沙箱工具」页面创建的沙箱工具名称（对应 E2B SDK 的 template 参数）
SANDBOX_TEMPLATE=code-interpreter-v1
# 沙箱接入域名（默认走广州地域；按地域改）
# E2B_DOMAIN=ap-guangzhou.tencentags.com
# 单沙箱存活上限（秒，默认 600）与单次 run_code 超时（秒，默认 120）
# SANDBOX_TIMEOUT=600
# SANDBOX_RUN_TIMEOUT=120

# —— 腾讯云数据库 Agent Memory（跨会话记忆）——
# 控制台实例详情页「API 接入」区域展示：https://console.cloud.tencent.com/tdai/memory
AGENT_MEMORY_ENDPOINT=https://<your-memory-endpoint>
AGENT_MEMORY_API_KEY=
# Memory 实例 ID（控制台「实例列表」可见，形如 mem-xxxxxxxx）；
# 官方 Python SDK 的 MemoryClient 三必填项之一，注入 HTTP 头 x-tdai-service-id。
AGENT_MEMORY_SERVICE_ID=mem-xxxxxxxx
# 检索召回条数与 HTTP 超时（可选）
# AGENT_MEMORY_TOP_K=5
# AGENT_MEMORY_TIMEOUT=10

# —— 日志（可选）——
# 设置后应用日志（含 uvicorn 访问/错误日志）写入该文件并按大小轮转；
# 不设则仅输出到 stdout（本地默认行为）。部署侧由脚本写入 /var/log/agent/app.log。
# LOG_FILE=/var/log/agent/app.log
# LOG_LEVEL=INFO
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# —— 以下为高级回退，一般无需设置 ——
# 智谱 OpenAI 兼容端点（仅在自定义端点时覆盖）
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# 智谱专用 key 回退（优先级低于 MODEL_API_KEY）
# ZHIPU_API_KEY=
# tokenhub 专用 key 回退（优先级低于 MODEL_API_KEY）
# TOKENHUB_API_KEY=
