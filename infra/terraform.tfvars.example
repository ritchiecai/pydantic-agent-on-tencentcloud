############################################################
# terraform.tfvars 占位示例
#
# ⚠️ 密钥变量（tencentcloud_secret_id / tencentcloud_secret_key /
#    model_api_key）请勿写真实值到本文件！本文件仅放非密钥占位。
#    密钥统一经环境变量注入：
#      export TF_VAR_tencentcloud_secret_id=...
#      export TF_VAR_tencentcloud_secret_key=...
#      export TF_VAR_model_api_key=...
############################################################

region             = "ap-guangzhou"
availability_zone  = "ap-guangzhou-3"
cvm_instance_type  = "SA2.MEDIUM4"
cvm_image_id       = "img-487zeit5" # 替换为本账号可用的 Ubuntu 22.04 image_id
model_provider     = "openai"        # openai（默认）| deepseek | zhipu | tokenhub
model_string       = "openai:gpt-4o-mini"
model_base_url     = ""              # 留空走 provider 代码默认值；tokenhub 等自定义端点在此覆盖
# 切 DeepSeek：model_provider="deepseek", model_string="deepseek-chat"
# 切 智谱：    model_provider="zhipu",    model_string="glm-4"
# 切 tokenhub：model_provider="tokenhub", model_string="gpt-4o-mini",
#             model_base_url="http://43.163.42.168/tokenhub/v1"（留空则用代码默认值）
ssl_certificate_id = ""             # 留空走 HTTP:80；补证书后填腾讯云证书 ID 启用 HTTPS:443

# —— 应用源码 git ref（灰度部署）——
# 默认部署 main；先在分支上验证通过再合主干时，改成分支名（如 feat/xxx）。
# app_git_repo = "https://github.com/ritchiecai/pydantic-agent-on-tencentcloud.git"
# app_git_ref  = "main"

# —— 腾讯云 Agent Runtime（代码沙箱，E2B 兼容）——
sandbox_template = "code-interpreter-v1"   # 控制台「沙箱工具」创建的工具名
runtime_domain   = ""                       # 留空走代码默认 ap-guangzhou.tencentags.com

# —— 腾讯云数据库 Agent Memory ——
memory_endpoint   = ""                      # 控制台实例详情页「API 接入」展示
memory_service_id = ""                      # 实例 ID（形如 mem-xxxxxxxx），控制台「实例列表」可见

# <set via TF_VAR_tencentcloud_secret_id, do NOT commit>
# <set via TF_VAR_tencentcloud_secret_key, do NOT commit>
# <set via TF_VAR_model_api_key, do NOT commit>
# <set via TF_VAR_runtime_api_key, do NOT commit>
# <set via TF_VAR_memory_api_key, do NOT commit>
